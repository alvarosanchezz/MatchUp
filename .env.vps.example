# ── MatchUp · Variables de entorno para VPS de clase ──────────────────────
# En el VPS ejecutar:
#   cp .env.vps.example .env
#   docker compose -f docker-compose.vps.yml up -d

# ── Base de datos ──────────────────────────────────────────────────────────
DB_NAME=matchup_db
DB_USER=matchup_user
DB_PASS=matchup_pass_vps

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=vps-clase-secret-key-matchup-2daw-asanrod603d-2025-min256bits
JWT_EXPIRATION_MS=900000
JWT_REFRESH_MS=604800000

# ── Correo (opcional; déjalo vacío si no usas email) ──────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://asanrod603d,http://localhost,http://127.0.0.1

# ── Imágenes Docker Hub ────────────────────────────────────────────────────
DOCKER_IMAGE_BACKEND=alvarosanchezz/matchup-backend:latest
DOCKER_IMAGE_FRONTEND=alvarosanchezz/matchup-frontend:latest
