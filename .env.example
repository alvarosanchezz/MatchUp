# ─── Copia este archivo a .env y rellena los valores reales ─────────────────
# NUNCA subas .env al repositorio (ya está en .gitignore)

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=matchup_db
DB_USER=matchup_user
DB_PASS=matchup_pass

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_64
JWT_EXPIRATION_MS=900000
JWT_REFRESH_MS=604800000

# ── Correo (Gmail: usar App Password, no la contraseña normal) ────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password_de_gmail

# ── Spring ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
